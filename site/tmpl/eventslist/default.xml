<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="com_planjeagenda_EVENTSLIST_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[com_planjeagenda_EVENTSLIST_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="params">
        <fieldset name="basic" addfieldpath="/administrator/components/com_planjeagenda/models/fields">
            <field name="show_archived_events" type="radio"
                   default="0"
                   label="com_planjeagenda_SHOW_ONLY_ARCHIVED_EVENTS"
                   description="com_planjeagenda_SHOW_ONLY_ARCHIVED_EVENTS_DESC"
                   class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="onlyfeatured" type="radio"
                default="0"
                label="com_planjeagenda_DISPLAY_FEATUREDONLY"
                description="com_planjeagenda_DISPLAY_FEATUREDONLY_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_introtext_events" type="radio"
                default="0"
                label="com_planjeagenda_SHOW_INTROTEXT_EVENTS"
                description="com_planjeagenda_SHOW_INTROTEXT_EVENTS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showiconsinorder" type="radio"
                default="1"
                label="com_planjeagenda_SHOW_ICONS_IN_ORDER"
                description="com_planjeagenda_SHOW_ICONS_IN_ORDER_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showiconsineventtitle" type="radio"
                default="1"
                label="com_planjeagenda_SHOW_ICONS_IN_EVENT_TITLE"
                description="com_planjeagenda_SHOW_ICONS_IN_EVENT_TITLE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showiconsineventdata" type="radio"
                default="1"
                label="com_planjeagenda_SHOW_ICONS_IN_EVENT_DATA"
                description="com_planjeagenda_SHOW_ICONS_IN_EVENT_DATA_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="tableorderby" type="radio"
                default="0"
                label="com_planjeagenda_TABLE_ORDER_BY"
                description="com_planjeagenda_TABLE_ORDER_BY_DESC"
                class="btn-group"
            >
                <option value="0">com_planjeagenda_DATE</option>
                <option value="1">com_planjeagenda_TITLE</option>
                <option value="2">com_planjeagenda_VENUE</option>
                <option value="3">com_planjeagenda_CITY</option>
                <option value="4">com_planjeagenda_STATE</option>
                <option value="5">com_planjeagenda_CATEGORY</option>
            </field>
        <field name="tabledirectionorder" type="radio"
            default="ASC"
            label="com_planjeagenda_TABLE_DIRECTION_ORDER"
            description="com_planjeagenda_TABLE_DIRECTION_ORDER_DESC"
            class="btn-group "
        >
            <option value="ASC">com_planjeagenda_ORDER_ASCENDING</option>
            <option value="DESC">com_planjeagenda_ORDER_DESCENDING</option>
        </field>
            <field name="tablefiltereventfrom" type="number"
                default="0"
                filter="integer"
                min="0"
                step="1"
                validate="number"
                label="com_planjeagenda_FILTER_EVENT_FROM"
                description="com_planjeagenda_FILTER_EVENT_FROM_DESC"
             class="w-auto" />
            <field name="tablefiltereventuntil" type="number"
                default="0"
                filter="integer"
                min="0"
                step="1"
                validate="number"
                label="com_planjeagenda_FILTER_EVENT_UNTIL"
                description="com_planjeagenda_FILTER_EVENT_UNTIL_DESC"
              class="w-auto" />
            <field name="showmonthrow" type="radio"
                default="0"
                label="com_planjeagenda_DISPLAY_MONTH_ROW"
                description="com_planjeagenda_DISPLAY_MONTH_ROW_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_more_button" type="radio" 
                   default="0" 
                   label="com_planjeagenda_SHOW_MORE_BUTTON" 
                   description="com_planjeagenda_SHOW_MORE_BUTTON_DESC"
                   class="inputbox btn-group btn-group-yesno"
                   required="false"
                >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="tabledirectionorder" type="radio"
                default="ASC"
                label="com_planjeagenda_TABLE_DIRECTION_ORDER"
                description="com_planjeagenda_TABLE_DIRECTION_ORDER_DESC"
                class="btn-group "
            >
                <option value="ASC">com_planjeagenda_ORDER_ASCENDING</option>
                <option value="DESC">com_planjeagenda_ORDER_DESCENDING</option>
            </field>
      <field type="spacer" name="spacer1" hr="true" />
      <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="com_planjeagenda_INTROTEXT_FIELD"
                description="com_planjeagenda_INTROTEXT_FIELD_DESC"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="com_planjeagenda_DISPLAY_INTROTEXT"
                description="com_planjeagenda_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field type="spacer" name="spacer2" hr="true" />
            <field name="categoryswitch" type="radio"
                default="0"
                label="com_planjeagenda_CATEGORYSWITCH"
                description="com_planjeagenda_CATEGORYSWITCH_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">com_planjeagenda_INCLUDE</option>
                <option value="0">com_planjeagenda_EXCLUDE</option>
            </field>
            <field name="categoryswitchcats" type="text"
                default=""
                label="com_planjeagenda_CATEGORYSWITCHCATS"
                description="com_planjeagenda_CATEGORYSWITCHCATS_DESC"
            />
            <field name="includesubcategories" type="radio"
                default="0"
                label="com_planjeagenda_INCLUDE_SUBCATEGORIES"
                description="com_planjeagenda_INCLUDE_SUBCATEGORIES_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showopendates" type="list"
                default="0"
                label="com_planjeagenda_GLOBAL_FIELD_SHOW_OPENDATES"
                description="com_planjeagenda_GLOBAL_FIELD_SHOW_OPENDATES_DESC"
            >
                <option value="0">JNO</option>
                <option value="1">com_planjeagenda_SHOW_OPENDATES_TOO</option>
                <option value="2">com_planjeagenda_SHOW_OPENDATES_ONLY</option>
            </field>
            <field type="spacer" name="spacer3" hr="true" />
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="com_planjeagenda_GLOBAL_FIELD_FOOTERTEXT"
                description="com_planjeagenda_GLOBAL_FIELD_FOOTERTEXT_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="com_planjeagenda_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="com_planjeagenda_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
        </fieldset>
    </fields>
</metadata>