<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="com_planjeagenda_CATEGORY_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[com_planjeagenda_CATEGORY_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="request">
        <fieldset name="request"
            addfieldpath="/administrator/components/com_planjeagenda/models/fields"
        >
            <field name="id" type="categories"
                default=""
                label="com_planjeagenda_SELECT_CATEGORY"
                description="com_planjeagenda_SELECT_CATEGORY_DESC"
                required="true"
            />
        </fieldset>
    </fields>

    <fields name="params">
        <fieldset name="basic">
            <field name="introtext" type="editor"
                   filter="safehtml"
                   hide="readmore,pagebreak,module,menu,fields,contact,article"
                   default=""
                   rows="8"
                   cols="30"
                   height="300px"
                   label="com_planjeagenda_INTROTEXT_FIELD"
                   description="com_planjeagenda_INTROTEXT_FIELD_DESC"
            />
            <field name="showintrotext" type="radio"
                   default="0"
                   label="com_planjeagenda_DISPLAY_INTROTEXT"
                   description="com_planjeagenda_DISPLAY_INTROTEXT_DESC"
                   class="btn-group btn-group-yesno"
            >
                <option value="1">com_planjeagenda_SHOW</option>
                <option value="0">com_planjeagenda_HIDE</option>
            </field>
            <field name="usecat" type="radio"
                default="1"
                label="com_planjeagenda_DISPLAYCHILDS"
                description="com_planjeagenda_DISPLAYCHILDSDESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showemptychilds" type="radio"
                default="1"
                label="com_planjeagenda_SHOWEMPTYCHILD"
                description="com_planjeagenda_SHOWEMPTYCHILDDESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="includechildevents" type="radio"
                   default="0"
                   label="com_planjeagenda_INCLUDE_CHILD_EVENTS"
                   description="com_planjeagenda_INCLUDE_CHILD_EVENTS_DESC"
                   class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
        </fieldset>
    </fields>
