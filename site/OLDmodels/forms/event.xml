<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fieldset name="details">
        <field name="articletext" type="editor"
        class="inputbox"
        label="com_planjeagenda_EDITEVENT_FIELD_DESCRIPTION"
        description="com_planjeagenda_EDITEVENT_FIELD_DESCRIPTION_DESC"
        filter="\Joomla\CMS\Component\ComponentHelper::filterText"
        hide="pagebreak"
    />
        <field name="featured" class="inputbox" type="list"
            label="JFEATURED"
            description="com_planjeagenda_EDITEVENT_FIELD_FEATURED_DESC"
            default="0"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="title" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_EDITEVENT_FIELD_EVENT_TITLE"
            description="com_planjeagenda_EDITEVENT_FIELD_EVENT_TITLE_DESC"
            required="true"
        />
        <field name="alias" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_EDITEVENT_FIELD_ALIAS"
            description="com_planjeagenda_EDITEVENT_FIELD_ALIAS"
            hint="JFIELD_ALIAS_PLACEHOLDER"
            required="false"
        />
        <field name="dates" type="calendarjem"
            label="com_planjeagenda_EDITEVENT_FIELD_DATE"
            description="com_planjeagenda_EDITEVENT_FIELD_DATE_DESC"
            class="inputbox"
            size="22"
            format="%Y-%m-%d"
            translateformat="true"
            filter="string"
            showtime="false"
        />
        <field name="enddates" type="calendarjem"
            label="com_planjeagenda_EDITEVENT_FIELD_ENDDATE"
            description="com_planjeagenda_EDITEVENT_FIELD_ENDDATE_DESC"
            class="inputbox"
            size="22"
            format="%Y-%m-%d"
            translateformat="true"
            filter="string"
            showtime="false"
        />
        <field name="times" type="starttime"
            class="inputbox"
            size="10"
            label="com_planjeagenda_EDITEVENT_FIELD_EVENT_TIME"
            description="com_planjeagenda_EDITEVENT_FIELD_EVENT_TIME_DESC"
            required="false"
        />
        <field name="endtimes" type="endtime"
            class="inputbox"
            size="10"
            label="com_planjeagenda_EDITEVENT_FIELD_END_TIME"
            description="com_planjeagenda_EDITEVENT_FIELD_END_TIME_DESC"
            required="false"
        />
        <field name="cats" type="catoptions"
            multiple="true"
            class="inputbox required form-control"
            size="4"
            label="com_planjeagenda_EDITEVENT_FIELD_CATEGORIES"
            labelclass=""
            description="com_planjeagenda_EDITEVENT_FIELD_CATEGORIES_DESC"
            required="true"
        />
    </fieldset>

    <fieldset name="publish">
        <field name="id" type="text"
            default="0"
            readonly="true"
            class="readonly"
            label="JGLOBAL_FIELD_ID_LABEL"
            description="JGLOBAL_FIELD_ID_DESC"
        />
        <field name="created" type="calendar"
            class="readonly"
            label="JGLOBAL_FIELD_CREATED_LABEL"
            description="JGLOBAL_FIELD_CREATED_DESC"
            size="22"
            default="now"
            readonly="true"
            format="Y-m-d H:i:s"
            translateformat="true"
            filter="user_utc"
        />
        <field name="modified" type="calendar"
            class="readonly"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            description="com_planjeagenda_EDITEVENT_FIELD_EDITED_AT"
            size="22"
            readonly="true"
            format="Y-m-d H:i:s"
            translateformat="true"
            filter="user_utc"
        />
        <field name="version" type="text"
            default="0"
            readonly="true"
            class="readonly"
            label="com_planjeagenda_EDITEVENT_FIELD_REVISED"
            description="com_planjeagenda_EDITEVENT_FIELD_REVISED"
        />
        <field name="created_by" type="user"
            label="JGLOBAL_FIELD_CREATED_BY_LABEL"
            description="JGLOBAL_FIELD_CREATED_BY_Desc"
        />
        <field name="published" type="list"
            label="JSTATUS"
            description="com_planjeagenda_EDITEVENT_FIELD_PUBLISHED_DESC"
            class="inputbox"
            size="1"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field name="publish_up" type="calendar"
            label="JGLOBAL_FIELD_PUBLISH_UP_LABEL"
            description="JGLOBAL_FIELD_PUBLISH_UP_DESC"
            size="22"
            default="now"
            format="%Y-%m-%d %H:%M:%S"
            translateformat="true"
            filter="user_utc"
            showtime="true"
            filterformat="%Y-%m-%d %H:%M:%S"
        />
        <field name="publish_down" type="calendar"
            label="JGLOBAL_FIELD_PUBLISH_DOWN_LABEL"
            description="JGLOBAL_FIELD_PUBLISH_DOWN_DESC"
            size="22"
            format="%Y-%m-%d %H:%M:%S"
            translateformat="true"
            filter="user_utc"
            showtime="true"
            filterformat="%Y-%m-%d %H:%M:%S"
        />
        <field name="access" type="list"
                label="JFIELD_ACCESS_LABEL"
                description="JFIELD_ACCESS_DESC"
                class="inputbox"
                size="1"
    />
    </fieldset>

    <fieldset name="request">
        <field name="locid" type="modal_venue"
            label="com_planjeagenda_EDITEVENT_FIELD_VENUE"
            description="com_planjeagenda_EDITEVENT_FIELD_VENUE_DESC"
            size="40"
            required="false"
            default="0"
        />
        <field name="contactid" type="modal_contact"
            label="com_planjeagenda_EDITEVENT_FIELD_CONTACT"
            description="com_planjeagenda_EDITEVENT_FIELD_CONTACT_DESC"
            size="40"
            required="false"
        />
    </fieldset>

    <fieldset name="image"
              label="com_planjeagenda_IMAGE"
    >
        <field name="datimage" type="imageselectevent"
            class="inputbox"
            size="40"
            label="com_planjeagenda_EDITEVENT_FIELD_IMAGESELECT"
            description="com_planjeagenda_EDITEVENT_FIELD_IMAGESELECT_DESC"
        />
        <field name="userfile" type="file"
            class="inputbox"
            size="40"
            label="com_planjeagenda_IMAGE"
            description="com_planjeagenda_UPLOAD_IMAGE"
        />
    </fieldset>

    <fieldset name="custom">
        <field name="custom1" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD1"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD1_DESC"
        />
        <field name="custom2" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD2"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD2_DESC"
        />
        <field name="custom3" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD3"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD3_DESC"
        />
        <field name="custom4" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD4"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD4_DESC"
        />
        <field name="custom5" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD5"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD5_DESC"
        />
        <field name="custom6" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD6"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD6_DESC"
        />
        <field name="custom7" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD7"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD7_DESC"
        />
        <field name="custom8" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD8"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD8_DESC"
        />
        <field name="custom9" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD9"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD9_DESC"
        />
        <field name="custom10" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_EVENT_CUSTOM_FIELD10"
            description="com_planjeagenda_EVENT_CUSTOM_FIELD10_DESC"
        />
    </fieldset>

    <fieldset name="registration">
        <field name="registra" type="list"
            label="com_planjeagenda_EVENT_FIELD_ENABLE_REGISTRATION"
            description="com_planjeagenda_EVENT_FIELD_ENABLE_REGISTRATION_DESC"
            class="inputbox"
            default="0"
            required="false"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
            <option value="2">com_planjeagenda_EVENT_FIELD_FROM</option>
        </field>
        <field name="registra_from" type="calendar"
            label="com_planjeagenda_EVENT_FIELD_REGISTRATION_FROM"
            description="com_planjeagenda_EVENT_FIELD_REGISTRATION_FROM_DESC"
            class="input-medium"
            default="now"
            filter="user_utc"
            format="%Y-%m-%d %H:%M:%S"
            filterformat="Y-m-d H:i:s"
            singleheader="true"
            showtime="true"
            timeformat="24"
            todaybutton="true"
            weeknumbers="true"
            filltable="true"
            showon="registra:2"
        />

        <field name="registra_until" type="calendar"
            label="com_planjeagenda_EVENT_FIELD_REGISTRATION_UNTIL"
            description="com_planjeagenda_EVENT_FIELD_REGISTRATION_UNTIL_DESC"
            class="input-medium"
            filter="user_utc"
            format="%Y-%m-%d %H:%M:%S"
            filterformat="Y-m-d H:i:s"
            singleheader="true"
            showtime="true"
            timeformat="24"
            todaybutton="true"
            weeknumbers="true"
            filltable="true"
            showon="registra:2"
        />
        <field name="reginvitedonly" type="checkbox"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_REG_INVITED_ONLY"
            description="com_planjeagenda_EDITEVENT_FIELD_REG_INVITED_ONLY_DESC"
            checked="0"
        />
        <field name="unregistra" type="list"
            label="com_planjeagenda_EVENT_FIELD_ENABLE_ANNULATION"
            description="com_planjeagenda_EVENT_FIELD_ENABLE_ANNULATION_DESC"
            class="inputbox"
            default="0"
            required="false"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
            <option value="2">com_planjeagenda_EVENT_FIELD_UNTIL</option>
        </field>
        <field name="unregistra_until" type="calendar"
            label="com_planjeagenda_EVENT_FIELD_ANNULATION_UNTIL"
            description="com_planjeagenda_EVENT_FIELD_ANNULATION_UNTIL_DESC"
            class="input-medium"
            filter="user_utc"
            format="%Y-%m-%d %H:%M:%S"
            filterformat="Y-m-d H:i:s"
            singleheader="true"
            showtime="true"
            timeformat="24"
            todaybutton="true"
            weeknumbers="true"
            filltable="true"
            showon="unregistra:2"
        />
        <field name="maxplaces" type="number"
            size="4"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_MAX_PLACES"
            description="com_planjeagenda_EDITEVENT_FIELD_MAX_PLACES_DESC"
            filter="integer"
            default="0"
            min="0"
        />
        <field name="minbookeduser" type="number"
            size="4"
            class="inputbox"
            label="com_planjeagenda_MINIMUM_BOOKED_PLACES_PER_USER"
            description="com_planjeagenda_MINIMUM_BOOKED_PLACES_PER_USER_DESC"
            filter="integer"
            default="1"
            min="1"
        />
        <field name="maxbookeduser" type="number"
            size="4"
            class="inputbox"
            label="com_planjeagenda_MAXIMUM_BOOKED_PLACES_PER_USER"
            description="com_planjeagenda_MAXIMUM_BOOKED_PLACES_PER_USER_DESC"
            filter="integer"
            default="1"
            min="1"
        />
        <field name="reservedplaces" type="number"
            size="4"
            class="inputbox"
            label="com_planjeagenda_RESERVED_PLACES"
            description="com_planjeagenda_RESERVED_PLACES_DESC"
            filter="integer"
            default="0"
            min="0"
        />
        <field name="invited" type="modal_users"
            label="com_planjeagenda_EDITEVENT_FIELD_INVITED_USERS"
            description="com_planjeagenda_EDITEVENT_FIELD_INVITED_USERS_DESC"
            size="4"
            required="false"
        />
        <field name="avplaces" type="text"
            size="4"
            class="readonly"
            readonly="true"
            disabled="true"
            label="com_planjeagenda_AVAILABLE_PLACES"
            description="com_planjeagenda_AVAILABLE_PLACES_DESC"
        />
        <field name="waitinglist" type="checkbox"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_ENABLE_WAITINGLIST"
            description="com_planjeagenda_EDITEVENT_FIELD_ENABLE_WAITINGLIST_DESC"
            checked="0"
        />
        <field name="requestanswer" type="checkbox"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_REQUEST_ANSWER_ASSISTENCE"
            description="com_planjeagenda_EDITEVENT_FIELD_REQUEST_ANSWER_ASSISTENCE_DESC"
            checked="0"
        />
        <field name="seriesbooking" type="checkbox"
            size="1"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_SERIES_EVENT_BOOKING"
            description="com_planjeagenda_EDITEVENT_FIELD_SERIES_EVENT_BOOKING_DESC"
            checked="0"
        />
        <field name="singlebooking" type="checkbox"
            size="1"
            class="inputbox"
            label="com_planjeagenda_EDITEVENT_FIELD_SINGLE_EVENT_BOOKING"
            description="com_planjeagenda_EDITEVENT_FIELD_SINGLE_EVENT_BOOKING_DESC"
            checked="0"
        />
    </fieldset>

    <fieldset name="recurrence"
              label="com_planjeagenda_EDITEVENT_FIELD_RECURRING_EVENTS"
    >
        <field name="recurrence_type" type="list"
            default="0"
            label="com_planjeagenda_EDITEVENT_FIELD_RECURRENCE"
            description="com_planjeagenda_EDITEVENT_FIELD_RECURRENCE"
        >
            <option value="0">com_planjeagenda_NOTHING</option>
            <option value="1">com_planjeagenda_DAILY</option>
            <option value="2">com_planjeagenda_WEEKLY</option>
            <option value="3">com_planjeagenda_MONTHLY</option>
            <option value="4">com_planjeagenda_WEEKDAY</option>
            <option value="5">com_planjeagenda_YEARLY</option>
            <option value="6">com_planjeagenda_LASTDAY</option>
        </field>
        <field name="recurrence_limit_date" type="calendarjem"
            default="now"
            label="com_planjeagenda_EDITEVENT_FIELD_RECURRENCE_COUNTER"
            description="com_planjeagenda_EDITEVENT_FIELD_RECURRENCE_COUNTER"
            class="inputbox"
            size="22"
            format="%Y-%m-%d"
            translateformat="true"
            filter="string"
            showtime="false"
        />
    </fieldset>

</form>
