<?xml version="1.0" encoding="UTF-8"?>
<form>
    <config>
        <inlinehelp button="show"/>
    </config>
    <fieldset name="details"
        addfieldprefix="KoelmanLabs\Component\Planjeagenda\Administrator\Field"
    >
        <field name="id" type="text"
            default="0"
            readonly="true"
            class="readonly"
            label="JGLOBAL_FIELD_ID_LABEL"
            description ="JGLOBAL_FIELD_ID_DESC"
        />
        <field name="venue" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_VENUE"
            description="com_planjeagenda_VENUE"
            required="true"
        />
        <field
			name="municipality_id"
			type="sql"
			label="COM_PLANJEAGENDA_VENUE_MUNICIPALITY_LABEL"
			query="SELECT id AS value, title AS text FROM #__pja_municipalities ORDER BY title ASC"
			header="COM_PLANJEAGENDA_SELECT_MUNICIPALITY"
			required="true"
			class="form-select"
		/>

		<field
			name="village_id"
			type="sql"
			label="COM_PLANJEAGENDA_VENUE_VILLAGE_LABEL"
			query="SELECT id AS value, title AS text FROM #__pja_villages ORDER BY title ASC"
			header="COM_PLANJEAGENDA_SELECT_VILLAGE"
			required="true"
			class="form-select"
		/>
        
        
        <field name="alias" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_ALIAS"
            description="com_planjeagenda_ALIAS"
            hint="JFIELD_ALIAS_PLACEHOLDER"
        />
        <field name="color" type="color"
            class="form-control"
            default=""
            size="8"
            label="com_planjeagenda_VENUE_COLOR"
            description="com_planjeagenda_VENUE_COLOR"
        />
        <field name="url" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_WEBSITE"
            description="com_planjeagenda_WEBSITE_DESC"
        />
        <field name="street" type="text"
            id="street"
            class="inputbox"
            size="40"
            label="com_planjeagenda_STREET"
            description="com_planjeagenda_STREET"
        />
        <field name="locdescription" type="editor"
            filter="\Joomla\CMS\Component\ComponentHelper::filterText"
            hide="pagebreak,readmore,image"
            class="inputbox"
            rows="3" cols="20"
            width="100%"
            label="com_planjeagenda_VENUE_FIELD_DESCRIPTION"
            description="com_planjeagenda_VENUE_FIELD_DESCRIPTION_DESC"
        />
        <field name="latitude" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_LATITUDE"
            description="com_planjeagenda_LATITUDE_DESC"
        />
        <field name="longitude" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_LONGITUDE"
            description="com_planjeagenda_LONGITUDE_DESC"
        />
        <field name="postalCode" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_ZIP"
            description="com_planjeagenda_ZIP"
        />
        <field name="city" type="text"
            class="inputbox"
            size="40"
            label="com_planjeagenda_CITY"
            description="com_planjeagenda_CITY"
        />
        <field name="state" type="text"
            class="inputbox"
            size="40"
            label="COM_PLANJEAGENDA_VENUE_PROVINCE_LABEL"
            description="COM_PLANJEAGENDA_VENUE_PROVINCE_DESC"
        />
        <field name="map" type="checkbox"
            class="inputbox"
            size="40"
            label="com_planjeagenda_ENABLE_MAP"
            description="com_planjeagenda_ENABLE_MAP"
            value="1"
            checked="0"
        />
        <field name="locimage" type="imageselect"
            class="inputbox"
            size="40"
            imagetype="venues"
            label="com_planjeagenda_IMAGESELECT"
            description="com_planjeagenda_IMAGESELECT"
        />
        <field name="published" type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            class="inputbox m-0"
            filter="intval"
            size="1"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field name="country" type="countryoptions"
            label="com_planjeagenda_GLOBAL_FIELD_COUNTRY"
            description="com_planjeagenda_GLOBAL_FIELD_COUNTRY_DESC"
            class="select_country m-0"
        />
    </fieldset>

    <fieldset name="custom">
        <field name="custom1" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD1"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD1_DESC"
        />
        <field name="custom2" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD2"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD2_DESC"
        />
        <field name="custom3" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD3"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD3_DESC"
        />
        <field name="custom4" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD4"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD4_DESC"
        />
        <field name="custom5" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD5"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD5_DESC"
        />
        <field name="custom6" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD6"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD6_DESC"
        />
        <field name="custom7" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD7"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD7_DESC"
        />
        <field name="custom8" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD8"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD8_DESC"
        />
        <field name="custom9" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD9"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD9_DESC"
        />
        <field name="custom10" type="text"
            size="20"
            readonly="false"
            class="inputbox"
            label="com_planjeagenda_VENUE_CUSTOM_FIELD10"
            description="com_planjeagenda_VENUE_CUSTOM_FIELD10_DESC"
        />
    </fieldset>

    <fieldset name="publish"
        label="com_planjeagenda_FIELDSET_PUBLISHING"
    >
        <field name="created_by" type="user"
            label="com_planjeagenda_FIELD_CREATED_BY_LABEL"
            description="com_planjeagenda_FIELD_CREATED_BY_DESC"
        />
        <field name="created" type="calendar"
            class="readonly"
            label="JGLOBAL_FIELD_CREATED_LABEL"
            description="JGLOBAL_FIELD_CREATED_DESC"
            size="22"
            default="now"
            readonly="true"
            format="%Y-%m-%d %H:%M:%S"
            translateformat="false"
            filter="user_utc"
            showtime="true"
            filterformat="Y-m-d H:i:s"
        />
        <field name="version" type="text"
            class="readonly"
            label="com_planjeagenda_FIELD_VERSION_LABEL"
            description="com_planjeagenda_FIELD_VERSION_DESC"
            size="6"
            readonly="true"
            filter="unset"
        />
        <field name="modified" type="calendar"
            class="readonly"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            description="com_planjeagenda_FIELD_MODIFIED_DESC"
            size="22"
            readonly="true"
            format="%Y-%m-%d %H:%M:%S"
            translateformat="false"
            filter="user_utc"
            showtime="true"
            filterformat="Y-m-d H:i:s"
        />
        <field name="modified_by" type="user"
            label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
            class="readonly"
            readonly="true"
            filter="unset"
         />
    </fieldset>

    <fieldset name="meta"
        label="JGLOBAL_FIELDSET_METADATA_OPTIONS"
    >
        <field name="meta_keywords" type="textarea"
            class="inputbox"
            rows="3" cols="30"
            label="JFIELD_META_KEYWORDS_LABEL"
            description="com_planjeagenda_FIELD_METAKEYWORDS_DESC"
        />
        <field name="meta_description" type="textarea"
            class="inputbox"
            rows="3" cols="30"
            label="JFIELD_META_DESCRIPTION_LABEL"
            description="com_planjeagenda_FIELD_METADESCRIPTION_DESC"
        />
    </fieldset>
    		<field
			name="asset_id"
			type="hidden"
		/>
</form>