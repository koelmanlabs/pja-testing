<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter"  addfieldprefix="KoelmanLabs\Component\Planjeagenda\Administrator\Field">
        <!-- De Zoekbalk -->
        <field
            name="search"
            type="text"
            label="COM_PLANJEAGENDA_SEARCH_LABEL"
            description="COM_PLANJEAGENDA_SEARCH_DESC"
            hint="JSEARCH_FILTER"
        />

        <!-- Status Filter (Gepubliceerd/Gedepubliceerd/Prullenbak) -->
        <field
            name="state"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            onchange="this.form.submit();"
            >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
        
        
                <field name="datestart" type="calendarjem"
            label="com_planjeagenda_STARTDATE"
            description="com_planjeagenda_STARTDATE"
            class="inputbox"
            size="22"
            format="%Y-%m-%d"
            translateformat="true"
            filter="string"
            showtime="false"
        />
        <field name="dateend" type="calendarjem"
            label="com_planjeagenda_ENDDATE"
            description="com_planjeagenda_ENDDATE"
            class="inputbox"
            size="22"
            format="%Y-%m-%d"
            translateformat="true"
            filter="string"
            showtime="false"
        />
        
        
        
        		<field
			name="featured"
			type="list"
			label="JFEATURED"
			filtermode="selector"
			class="js-select-submit-on-change"
			validate="options"
			>
			<option value="">COM_CONTENT_SELECT_FEATURED</option>
			<option value="0">COM_CONTENT_FILTER_FEATURED_NO</option>
			<option value="1">COM_CONTENT_FILTER_FEATURED_YES</option>
		</field>
		
		
		
				<field
			name="access"
			type="accesslevel"
			label="JGRID_HEADING_ACCESS"
			multiple="true"
			layout="joomla.form.field.list-fancy-select"
			hint="JOPTION_SELECT_ACCESS"
			class="js-select-submit-on-change"
		/>
		
		       <field 
    name="municipality_id" 
    type="sql" 
    label="COM_PLANJEAGENDA_FIELD_MUNICIPALITY_LABEL"
    query="SELECT id AS value, title AS text FROM #__pja_municipalities WHERE published = 1 ORDER BY title ASC"
    key_field="value"
    value_field="text"
    required="true"
/>
		
    </fields>

    <fields name="list">
        <!-- Pagina limiet (hoeveel items per pagina) -->
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>