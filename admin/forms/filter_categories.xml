<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <!-- De Zoekbalk -->
        <field
            name="search"
            type="text"
            label="COM_PLANJEAGENDA_SEARCH_LABEL"
            description="COM_PLANJEAGENDA_SEARCH_DESC"
            hint="JSEARCH_FILTER"
        />

        <!-- Status Filter (Gepubliceerd/Gedepubliceerd/Prullenbak) -->
        <field
            name="state"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            onchange="this.form.submit();"
            >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
    </fields>

    <fields name="list">
        <!-- Pagina limiet (hoeveel items per pagina) -->
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>